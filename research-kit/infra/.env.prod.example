ENV=production
DATABASE_URL=postgresql+asyncpg://rk:CHANGE_ME@postgres:5432/rk
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=CHANGE_ME

# Auth
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
SESSION_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# LLM (used by /verify and /extract endpoints)
# Set at least one of these:
GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_PRIMARY_PROVIDER=openai   # openai | gemini

# MCP token (optional, only needed if you use the MCP endpoint)
RK_MCP_TOKEN=CHANGE_ME_use_openssl_rand_hex_32
