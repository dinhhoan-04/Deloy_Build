FROM python:3.12-slim

WORKDIR /app
ENV PYTHONUNBUFFERED=1 PIP_NO_CACHE_DIR=1 PYTHONPATH=/app/backend

COPY backend/pyproject.toml /app/backend/pyproject.toml
COPY shared /app/shared
RUN pip install -e /app/shared && pip install -e /app/backend

COPY backend /app/backend
COPY infra/scripts /app/scripts
RUN chmod +x /app/scripts/run-backend.sh /app/scripts/run-migrations.sh

WORKDIR /app/backend
EXPOSE 8000
CMD ["/app/scripts/run-backend.sh"]
