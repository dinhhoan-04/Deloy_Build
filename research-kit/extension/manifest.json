{
  "manifest_version": 3,
  "name": "Research Kit — Agent Assistant",
  "key": "",
  "version": "0.6.2",
  "description": "AI-powered verification and synthesis on academic research platforms",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "sidePanel",
    "identity"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:9000/*",
    "https://elicit.com/*",
    "https://scispace.com/*",
    "https://consensus.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://elicit.com/*",
        "https://elicit.org/*",
        "https://scispace.com/*",
        "https://consensus.app/*"
      ],
      "js": [
        "src/content.ts"
      ]
    }
  ],
  "action": {
    "default_title": "Research Kit Agent"
  },
  "side_panel": {
    "default_path": "src/sidebar/index.html"
  },
  "background": {
    "service_worker": "src/background_minimal.ts"
  }
}