# Choose one or both providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Default model
DEFAULT_MODEL=claude-sonnet-4-20250514
# DEFAULT_MODEL=gpt-4o

# Logging
LOG_LEVEL=INFO

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log

# Supabase (optional for cloud PDF storage + document registry)
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_BUCKET=PDF_Storage
SUPABASE_SERVICE_ROLE_KEY=
# or newer key format if preferred:
# SUPABASE_SECRET_KEY=
# Temporary owner id for app flows before login UI is implemented.
# Must match an existing auth.users.id UUID in Supabase.
DEFAULT_OWNER_USER_ID=

# Auto embedding (after chunk persistence)
AUTO_EMBEDDING_ENABLED=true
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_DISTANCE_METRIC=cosine
EMBEDDING_BATCH_SIZE=32

# Request anti-spam guard (per Streamlit session/thread_id)
RATE_LIMIT_MAX_REQUESTS=3
RATE_LIMIT_WINDOW_SECONDS=60
